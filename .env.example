# PostHog analytics — copy this file to .env.local and fill in your values.
# Create a free project at https://posthog.com, then Project Settings -> copy
# the "Project API Key" (starts with phc_).

# Your PostHog project API key (safe to expose; it's write-only).
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The PostHog UI host for your region. US: https://us.posthog.com
# EU: https://eu.posthog.com (also update the rewrite hosts in next.config.ts).
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# Absolute site origin — used for metadataBase, canonical, and OG image URLs.
NEXT_PUBLIC_SITE_URL=https://nima-karami.com

# --- Conversational layer (server-only; NEVER exposed to the client) ---
# Anthropic API key for the /api/chat route. Get one at https://console.anthropic.com.
# If unset, chat returns a graceful "warming up" message instead of erroring.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public Streamable-HTTP URL of the deployed nima-career-mcp server (…/mcp).
# Claude's MCP connector calls this server-side to ground answers in the corpus.
NIMA_MCP_URL=https://nima-career-mcp.fly.dev/mcp
