# PostHog analytics — copy this file to .env.local and fill in your values.
# Create a free project at https://posthog.com, then Project Settings -> copy
# the "Project API Key" (starts with phc_).

# Your PostHog project API key (safe to expose; it's write-only).
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The PostHog UI host for your region. US: https://us.posthog.com
# EU: https://eu.posthog.com (also update the rewrite hosts in next.config.ts).
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
